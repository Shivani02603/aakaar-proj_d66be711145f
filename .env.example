# Database connection string for PostgreSQL
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>

# Secret key for JWT authentication
JWT_SECRET=<random secret>

# Backend server port
PORT=8000

# Frontend API URL for development
VITE_API_URL=http://localhost:8000

# PostgreSQL database credentials
POSTGRES_USER=appuser  # Username for the PostgreSQL database
POSTGRES_PASSWORD=<password>  # Password for the PostgreSQL database
POSTGRES_DB=appdb  # Name of the PostgreSQL database

# OpenAI API key for generating embeddings
OPENAI_API_KEY=<your_openai_api_key>

# Optional: Other API keys for future integrations
ANTHROPIC_API_KEY=<your_anthropic_api_key>
GOOGLE_GEMINI_API_KEY=<your_google_gemini_api_key>
PINECONE_API_KEY=<your_pinecone_api_key>